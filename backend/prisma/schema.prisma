generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoUsuario {
  admin
  ong
  doador
}

enum StatusOng {
  pendente
  aprovado
  rejeitado
}

model User {
  id         Int         @id @default(autoincrement())
  nome       String
  email      String      @unique
  senha      String
  tipo       TipoUsuario @default(doador)
  nascimento DateTime?
  criadoEm   DateTime    @default(now()) @map("criado_em")
  ong        Ong?

  @@map("users")
}

model Ong {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique @map("user_id")
  nome      String
  descricao String
  categoria String
  cidade    String
  endereco  String
  cnpj      String    @unique
  pixChave  String    @map("pix_chave")
  pixTipo   String    @map("pix_tipo")
  status    StatusOng @default(pendente)
  email     String
  telefone  String
  instagram String?
  foto      String?
  criadoEm  DateTime  @default(now()) @map("criado_em")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campanhas Campanha[]

  @@map("ongs")
}

model Campanha {
  id         Int      @id @default(autoincrement())
  ongId      Int      @map("ong_id")
  titulo     String
  descricao  String
  meta       Decimal  @db.Decimal(12, 2)
  arrecadado Decimal  @default(0) @db.Decimal(12, 2)
  ativa      Boolean  @default(true)
  criadoEm   DateTime @default(now()) @map("criado_em")

  ong        Ong      @relation(fields: [ongId], references: [id], onDelete: Cascade)

  @@map("campanhas")
}
